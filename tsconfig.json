{
  "compilerOptions": {
    "baseUrl": "./",
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./docs/.vitepress/theme/*"],
      "~/*": ["./docs/.vitepress/theme/*"],
      "~~/*": ["./docs/.vitepress/*"]
    },
    "lib": ["esnext", "dom", "dom.iterable", "scripthost"],
    "skipLibCheck": true,
    "allowJs": true,
    "strict": false
  },
  "include": [
    "types/**/*.d.ts",
    "docs/*",
    "docs/*.tsx",
    "docs/*.ts",
    "docs/**/*.vue",
    "docs/**/*.tsx",
    "docs/**/*.ts",
    "docs/.**/**/*.ts",
    "docs/.**/**/*.tsx",
    "docs/.**/**/*.vue",
    "docs/.**/**/**/*.ts",
    "docs/.**/**/**/*.tsx",
    "docs/.**/**/**/*.vue"
  ],
  "exclude": ["**/node_modules/**", "**/dist/**"]
}
